{
  "name": "nexplay",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop anime media library with local playback, Bangumi metadata, danmaku, and download integration.",
  "license": "MIT",
  "homepage": "https://github.com/ddy314/NexPlay#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ddy314/NexPlay.git"
  },
  "bugs": {
    "url": "https://github.com/ddy314/NexPlay/issues"
  },
  "keywords": [
    "anime",
    "bangumi",
    "danmaku",
    "electron",
    "media-library",
    "mpv",
    "react",
    "rust"
  ],
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 && electron --no-sandbox .",
    "generate:types": "cargo run --quiet -- export-types",
    "test:backend-daemon": "node scripts/check-backend-daemon.cjs",
    "build:native-render": "node scripts/build-native-render.cjs",
    "diagnose:player": "node scripts/diagnose-player.cjs",
    "diagnose:danmaku": "node scripts/diagnose-danmaku.cjs",
    "diagnose:player:discover": "node scripts/diagnose-player.cjs --discover",
    "build": "tsc --noEmit && vite build",
    "build:backend": "cargo build --release",
    "prepare:release-assets": "node scripts/prepare-release-assets.cjs",
    "package": "npm run build && npm run build:backend && npm run build:native-render && npm run prepare:release-assets && electron-builder --dir",
    "dist": "npm run build && npm run build:backend && npm run build:native-render && npm run prepare:release-assets && electron-builder --publish never",
    "start": "NEXPLAY_RENDERER_MODE=production electron --no-sandbox .",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "clsx": "2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "node-addon-api": "^8.8.0",
    "node-vibrant": "^4.0.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "electron": "38.8.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0",
    "wait-on": "9.0.3"
  },
  "build": {
    "appId": "dev.nexplay.app",
    "productName": "NexPlay",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend"
      },
      {
        "from": "dist/native",
        "to": "native"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "AudioVideo"
    }
  }
}

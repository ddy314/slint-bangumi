{
  "name": "nexplay",
  "version": "0.1.0",
  "private": true,
  "description": "NexPlay local anime media library",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 && electron --no-sandbox .",
    "build": "tsc --noEmit && vite build",
    "start": "NEXPLAY_RENDERER_MODE=production electron --no-sandbox .",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "clsx": "2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "electron": "38.8.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0",
    "wait-on": "9.0.3"
  }
}

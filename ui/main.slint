                Text { x: 42px; y: 88px; text: "管理媒体目录、匹配策略与外部 API 凭证。"; color: #b6ada4; font-size: 14px; }

                HorizontalBox {
                    x: 40px;
                    y: 136px;
                    width: parent.width - 80px;
                    height: parent.height - 176px;
                    spacing: 28px;

                    Surface {
                        width: 260px;
                        height: 300px;
                        SettingsTab { x: 8px; y: 8px; width: parent.width - 16px; title: "Media Libraries"; desc: "目录、扫描计划与缓存"; active: root.settings_section == 0; clicked => { root.settings_section = 0; } }
                        SettingsTab { x: 8px; y: 72px; width: parent.width - 16px; title: "Match"; desc: "匹配策略与命名规则"; active: root.settings_section == 1; clicked => { root.settings_section = 1; } }
                        SettingsTab { x: 8px; y: 136px; width: parent.width - 16px; title: "API"; desc: "Bangumi · 弹幕源 · 凭证"; active: root.settings_section == 2; clicked => { root.settings_section = 2; } }
                        SettingsTab { x: 8px; y: 200px; width: parent.width - 16px; title: "About"; desc: "版本与依赖信息"; active: root.settings_section == 3; clicked => { root.settings_section = 3; } }
                    }

                    Rectangle {
                        height: parent.height;
                        width: parent.width - 288px;

                        if root.settings_section == 0 : Rectangle {
                            height: 560px;
                            Text { text: "媒体目录"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                            Surface {
                                y: 40px;
                                width: parent.width;
                                height: 200px;
                                Text { x: 22px; y: 22px; width: parent.width - 44px; text: root.settings_summary; color: #b6ada4; font-size: 12px; wrap: word-wrap; overflow: elide; }
                            }
                            HorizontalBox {
                                y: 258px;
                                spacing: 12px;
                                LineEdit { width: 420px; height: 42px; text <=> root.media_path_input; placeholder-text: "Add local media folder"; }
                                PrimaryButton { text: "添加目录"; clicked => { root.add_media_path(root.media_path_input); root.toast_text = "已添加媒体目录"; } }
                                PrimaryButton { tonal: true; text: "扫描全部"; clicked => { root.scan_library(); root.toast_text = "扫描已开始"; } }
                            }
                            Surface {
                                y: 326px;
                                width: parent.width;
                                height: 224px;
                                SettingsRow { y: 0px; width: parent.width; title: "启动时自动扫描"; desc: "启动 Komorebi 时检查所有已注册目录的变更"; enabled: true; has_switch: true; }
                                SettingsRow { y: 74px; width: parent.width; title: "添加时自动匹配"; desc: "新增文件自动查询 Bangumi 元数据"; enabled: root.bangumi_auto_match; has_switch: true; }
                                SettingsRow { y: 148px; width: parent.width; title: "并发线程"; desc: "扫描时同时处理的文件数量"; value: "4"; has_switch: false; }
                            }
                        }

                        if root.settings_section == 1 : Rectangle {
                            height: 380px;
                            Text { text: "匹配策略"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                            Surface {
                                y: 40px;
                                width: parent.width;
                                height: 232px;
                                SettingsRow { y: 0px; width: parent.width; title: "自动确认阈值"; desc: "匹配度高于 75% 时自动确认，否则标记为待确认"; value: "75%"; has_switch: false; }
                                SettingsRow { y: 74px; width: parent.width; title: "优先使用中文标题"; desc: "界面优先展示 zh-Hans 名称"; enabled: true; has_switch: true; }
                                SettingsRow { y: 148px; width: parent.width; title: "文件命名解析"; desc: "季度 · 集数 · 分辨率 · 字幕组"; value: "启用"; has_switch: false; }
                            }
                            PrimaryButton { y: 296px; width: 150px; text: "Match All"; clicked => { root.match_all_metadata(); root.toast_text = "已加入匹配队列"; } }
                        }

                        if root.settings_section == 2 : Rectangle {
                            height: 460px;
                            Text { text: "Bangumi API"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                            Surface {
                                y: 40px;
                                width: parent.width;
                                height: 232px;
                                SettingsRow { y: 0px; width: parent.width; title: "服务器"; desc: "API 基础地址"; value: "https://api.bgm.tv"; has_switch: false; }
                                SettingsRow { y: 74px; width: parent.width; title: "Bangumi metadata"; desc: "查询条目、获取元数据与同步收藏"; enabled: root.bangumi_enabled; has_switch: true; }
                                SettingsRow { y: 148px; width: parent.width; title: "DanDanPlay"; desc: "自动匹配并下载弹幕"; enabled: root.dandanplay_configured; has_switch: true; }
                            }
                            PrimaryButton { y: 296px; width: 128px; tonal: true; text: "Test"; clicked => { root.test_bangumi_connection(); root.toast_text = "正在测试连接"; } }
                            Surface {
                                y: 352px;
                                width: parent.width;
                                height: 96px;
                                border-color: #ffc46b66;
                                background: #ffc46b14;
                                Text { x: 22px; y: 18px; text: "凭证未同步"; color: #ffd89a; font-size: 14px; font-weight: 800; }
                                Text { x: 22px; y: 44px; width: parent.width - 180px; text: "本设备的 Bangumi Token 与云端不一致。是否需要使用云端配置覆盖？"; color: #ffe3b7; font-size: 12px; overflow: elide; }
                                PrimaryButton { x: parent.width - 116px; y: 30px; width: 86px; compact: true; tonal: true; text: "同步"; clicked => { root.toast_text = "同步功能待接入"; } }
                            }
                        }

                        if root.settings_section == 3 : Rectangle {
                            height: 300px;
                            Surface {
                                width: parent.width;
                                height: 116px;
                                Rectangle { x: 22px; y: 26px; width: 64px; height: 64px; border-radius: 18px; background: #ff8a65; Text { text: "★"; color: #2a1206; font-size: 34px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; } }
                                Text { x: 106px; y: 32px; text: "Komorebi · 本地番剧库"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                                Text { x: 106px; y: 64px; text: "v0.18.2 · Rust / Slint"; color: #b6ada4; font-size: 13px; }
                                PrimaryButton { x: parent.width - 134px; y: 38px; width: 104px; compact: true; outlined: true; text: "检查更新"; clicked => { root.toast_text = "当前已是最新"; } }
                            }
                            Surface {
                                y: 140px;
                                width: parent.width;
                                height: 150px;
                                SettingsRow { y: 0px; width: parent.width; title: "开源许可"; desc: "MIT License"; value: "查看"; has_switch: false; }
                                SettingsRow { y: 74px; width: parent.width; title: "第三方组件"; desc: "包含 Slint, rusqlite, reqwest 等"; value: "查看"; has_switch: false; }
                            }
                        }
                    }
                }
            }

            if root.toast_text != "" : Rectangle {
                x: parent.width / 2 - 190px;
                y: parent.height - 76px;
                width: 380px;
                height: 48px;
                border-radius: 18px;
                background: #3b3531ee;
                border-width: 1px;
                border-color: #ffffff1c;
                Text { x: 18px; width: parent.width - 62px; text: root.toast_text; color: #ffffff; font-size: 14px; vertical-alignment: center; overflow: elide; }
                IconButton { x: parent.width - 46px; y: 5px; mark: "×"; clicked => { root.toast_text = ""; } }
            }
        }
    }
}

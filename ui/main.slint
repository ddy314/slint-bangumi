import { Button, LineEdit, ListView, ScrollView, TextEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct UiMediaCard {
    media_id: int,
    subject_id: int,
    title: string,
    subtitle: string,
    status_text: string,
    match_status: string,
    progress_percent: int,
    episode_text: string,
    poster_path: string,
    poster_image: image,
    has_cached_poster: bool,
}

export struct UiMediaRow {
    card0: UiMediaCard,
    card1: UiMediaCard,
    card2: UiMediaCard,
    card3: UiMediaCard,
    card4: UiMediaCard,
    show0: bool,
    show1: bool,
    show2: bool,
    show3: bool,
    show4: bool,
}

export struct UiSubjectDetail {
    media_id: int,
    subject_id: int,
    title: string,
    title_cn: string,
    summary: string,
    air_date: string,
    rating_text: string,
    rank_text: string,
    poster_path: string,
    hero_path: string,
    poster_image: image,
    hero_image: image,
    match_status: string,
    cache_status: string,
}

export struct UiCandidate {
    candidate_id: int,
    media_id: int,
    title: string,
    subtitle: string,
    summary: string,
    score_text: string,
    selected: bool,
}

export struct UiLogLine {
    level: string,
    message: string,
    timestamp: string,
}

component ProgressBar inherits Rectangle {
    in property <int> value;
    in property <brush> fill: #ff8a65;

    height: 6px;
    border-radius: 3px;
    background: #ffffff1a;

    Rectangle {
        height: parent.height;
        width: parent.width * root.value / 100;
        border-radius: parent.border-radius;
        background: root.fill;
    }
}

component Surface inherits Rectangle {
    border-radius: 16px;
    background: #221e1b;
    border-width: 1px;
    border-color: #2e2a26;
}

component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> tonal;
    in property <bool> outlined;
    in property <bool> danger;
    in property <bool> compact;
    callback clicked();

    min-width: root.compact ? 92px : 132px;
    height: root.compact ? 34px : 42px;
    border-radius: root.compact ? 17px : 21px;
    border-width: root.outlined ? 1px : 0px;
    border-color: root.danger ? #ff6b6b66 : #4a423d;
    background: touch.pressed ? #5a3527 : touch.has-hover
        ? (root.danger ? #ff6b6b33 : root.outlined ? #ffffff12 : root.tonal ? #5a3527 : #ff9b78)
        : (root.danger ? #ff6b6b26 : root.outlined ? #00000000 : root.tonal ? #4a2a1f : #ff8a65);

    touch := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.text;
        color: root.danger ? #ffb4be : root.outlined ? #ece4dc : root.tonal ? #ff8a65 : #2a1206;
        font-size: root.compact ? 12px : 14px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component IconButton inherits Rectangle {
    in property <string> mark;
    in property <bool> active;
    callback clicked();

    width: 38px;
    height: 38px;
    border-radius: 19px;
    background: root.active ? #ffffff18 : touch.has-hover ? #ffffff12 : #00000000;

    touch := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.mark;
        color: root.active ? #ff8a65 : #b6ada4;
        font-size: 15px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component Badge inherits Rectangle {
    in property <string> text;
    in property <string> tone;

    height: 24px;
    min-width: 72px;
    border-radius: 12px;
    border-width: 1px;
    border-color: root.tone == "success" ? #6dd58c55 : root.tone == "warning" ? #ffc46b55 : root.tone == "danger" ? #ff6b6b55 : root.tone == "accent" ? #b18cff55 : #ff8a6555;
    background: root.tone == "success" ? #6dd58c26 : root.tone == "warning" ? #ffc46b26 : root.tone == "danger" ? #ff6b6b26 : root.tone == "accent" ? #b18cff26 : #ff8a6526;

    Text {
        x: 10px;
        width: parent.width - 20px;
        text: root.text;
        color: root.tone == "success" ? #9df0b4 : root.tone == "warning" ? #ffd89a : root.tone == "danger" ? #ffb4be : root.tone == "accent" ? #d2c0ff : #ffb199;
        font-size: 11px;
        font-weight: 750;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component Chip inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked();

    height: 32px;
    min-width: 78px;
    border-radius: 16px;
    border-width: 1px;
    border-color: root.selected ? #ff8a6670 : #4a423d;
    background: root.selected ? #4a2a1f : touch.has-hover ? #ffffff0f : #00000000;

    touch := TouchArea { clicked => { root.clicked(); } }

    Text {
        x: 14px;
        width: parent.width - 28px;
        text: root.selected ? "✓ " + root.text : root.text;
        color: root.selected ? #ff8a65 : #b6ada4;
        font-size: 13px;
        font-weight: root.selected ? 750 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> active;
    in property <bool> collapsed;
    callback clicked();

    height: 44px;
    border-radius: 12px;
    background: root.active ? #4a2a1f : touch.has-hover ? #ffffff0f : #00000000;

    touch := TouchArea { clicked => { root.clicked(); } }

    Rectangle {
        x: 0px;
        y: 10px;
        width: 4px;
        height: root.active ? 24px : 0px;
        border-radius: 2px;
        background: #ff8a65;
    }

    Text {
        x: root.collapsed ? 0px : 16px;
        width: root.collapsed ? parent.width : 24px;
        text: root.icon;
        color: root.active ? #ff8a65 : #b6ada4;
        font-size: 18px;
        font-weight: 850;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if !root.collapsed : Text {
        x: 52px;
        width: parent.width - 64px;
        text: root.label;
        color: root.active ? #ff8a65 : #b6ada4;
        font-size: 14px;
        font-weight: 650;
        vertical-alignment: center;
    }
}

component PosterBox inherits Rectangle {
    in property <UiMediaCard> card;
    in property <bool> small;

    border-radius: root.small ? 10px : 16px;
    background: root.card.has_cached_poster ? #14110f : #2f3935;
    clip: true;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.card.poster_image;
        image-fit: cover;
    }

    if !root.card.has_cached_poster : Text {
        text: "No Poster";
        color: #847d75;
        font-size: root.small ? 10px : 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component MediaCard inherits Rectangle {
    in property <UiMediaCard> card;
    in property <bool> selected;
    callback clicked(int);

    width: 180px;
    height: 318px;
    border-radius: 18px;
    background: #00000000;
    border-width: root.selected ? 2px : 0px;
    border-color: #ff8a65;

    touch := TouchArea { clicked => { root.clicked(root.card.media_id); } }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 180px;
        height: 270px;
        border-radius: 18px;
        background: touch.has-hover ? #322c28 : #221e1b;
        border-width: 1px;
        border-color: touch.has-hover ? #4a423d : #2e2a26;
        clip: true;

        PosterBox {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            card: root.card;
        }

        Rectangle {
            y: parent.height - 82px;
            width: parent.width;
            height: 82px;
            background: #00000099;
        }

        if root.card.progress_percent > 0 && root.card.progress_percent < 100 : ProgressBar {
            x: 12px;
            y: parent.height - 16px;
            width: parent.width - 24px;
            value: root.card.progress_percent;
        }

        Badge {
            x: parent.width - 84px;
            y: 10px;
            width: 74px;
            text: root.card.match_status == "matched" ? (root.card.episode_text == "" ? root.card.status_text : root.card.episode_text) : root.card.status_text;
            tone: root.card.match_status == "matched" ? "success" : root.card.match_status == "tentative" ? "warning" : root.card.match_status == "failed" ? "danger" : "accent";
        }

        if touch.has-hover : Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000066;
            Text {
                text: "▶";
                color: #2a1206;
                font-size: 26px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
                Rectangle {
                    x: parent.width / 2 - 26px;
                    y: parent.height / 2 - 26px;
                    width: 52px;
                    height: 52px;
                    border-radius: 26px;
                    background: #ff8a65;
                    z: -1;
                }
            }
        }
    }

    Text {
        x: 4px;
        y: 282px;
        width: parent.width - 8px;
        height: 20px;
        text: root.card.title;
        color: touch.has-hover ? #ff8a65 : #ece4dc;
        font-size: 14px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 4px;
        y: 304px;
        width: parent.width - 8px;
        height: 16px;
        text: root.card.subtitle;
        color: #847d75;
        font-size: 11px;
        overflow: elide;
    }
}

component ContinueCard inherits Surface {
    in property <UiMediaCard> card;
    callback clicked(int);

    height: 150px;
    background: touch.has-hover ? #2a2522 : #221e1b;

    touch := TouchArea { clicked => { root.clicked(root.card.media_id); } }

    PosterBox {
        x: 14px;
        y: 14px;
        width: 82px;
        height: 122px;
        small: true;
        card: root.card;
    }

    Text {
        x: 112px;
        y: 22px;
        width: parent.width - 240px;
        height: 24px;
        text: root.card.title;
        color: #ece4dc;
        font-size: 16px;
        font-weight: 750;
        overflow: elide;
    }

    Text {
        x: 112px;
        y: 50px;
        width: parent.width - 240px;
        height: 18px;
        text: root.card.subtitle;
        color: #847d75;
        font-size: 12px;
        overflow: elide;
    }

    Text {
        x: 112px;
        y: 78px;
        width: parent.width - 240px;
        text: root.card.episode_text == "" ? "EP -- · 最近播放 --" : root.card.episode_text;
        color: #b6ada4;
        font-size: 12px;
        overflow: elide;
    }

    ProgressBar {
        x: 112px;
        y: 112px;
        width: parent.width - 250px;
        value: root.card.progress_percent;
    }

    Text {
        x: 112px;
        y: 124px;
        width: 48px;
        text: root.card.progress_percent + "%";
        color: #847d75;
        font-size: 11px;
    }

    PrimaryButton {
        x: parent.width - 112px;
        y: 55px;
        width: 88px;
        compact: true;
        tonal: true;
        text: "继续";
        clicked => { root.clicked(root.card.media_id); }
    }
}

component ListRow inherits Rectangle {
    in property <UiMediaCard> card;
    callback clicked(int);

    height: 74px;
    background: touch.has-hover ? #ffffff0a : #00000000;

    touch := TouchArea { clicked => { root.clicked(root.card.media_id); } }

    PosterBox {
        x: 18px;
        y: 10px;
        width: 36px;
        height: 54px;
        small: true;
        card: root.card;
    }

    Text {
        x: 72px;
        y: 15px;
        width: parent.width - 520px;
        height: 20px;
        text: root.card.title;
        color: #ece4dc;
        font-size: 14px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 72px;
        y: 39px;
        width: parent.width - 520px;
        height: 18px;
        text: root.card.subtitle;
        color: #847d75;
        font-size: 12px;
        overflow: elide;
    }

    Badge {
        x: parent.width - 418px;
        y: 25px;
        width: 86px;
        text: root.card.status_text;
        tone: root.card.match_status == "matched" ? "success" : root.card.match_status == "tentative" ? "warning" : root.card.match_status == "failed" ? "danger" : "accent";
    }

    ProgressBar {
        x: parent.width - 300px;
        y: 28px;
        width: 110px;
        value: root.card.progress_percent;
    }

    Text {
        x: parent.width - 178px;
        y: 27px;
        width: 92px;
        text: root.card.episode_text == "" ? "--" : root.card.episode_text;
        color: #b6ada4;
        font-size: 12px;
        overflow: elide;
    }

    IconButton {
        x: parent.width - 54px;
        y: 18px;
        mark: "▶";
        active: true;
        clicked => { root.clicked(root.card.media_id); }
    }
}

component StatCard inherits Surface {
    in property <string> label;
    in property <string> value;
    in property <string> hint;

    height: 100px;

    Text { x: 16px; y: 16px; width: parent.width - 32px; text: root.label; color: #847d75; font-size: 11px; font-weight: 700; }
    Text { x: 16px; y: 38px; width: parent.width - 32px; text: root.value; color: #ece4dc; font-size: 26px; font-weight: 850; overflow: elide; }
    Text { x: 16px; y: 72px; width: parent.width - 32px; text: root.hint; color: #b6ada4; font-size: 12px; overflow: elide; }
}

component SectionTitle inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <bool> view_all;
    callback view_all_clicked();

    height: 54px;
    background: #00000000;

    Text { y: 0px; text: root.title; color: #ece4dc; font-size: 22px; font-weight: 800; }
    Text { y: 31px; text: root.subtitle; color: #847d75; font-size: 12px; font-weight: 700; }
    if root.view_all : Text {
        x: parent.width - 78px;
        y: 10px;
        text: "View All ›";
        color: #b6ada4;
        font-size: 13px;
        TouchArea { clicked => { root.view_all_clicked(); } }
    }
}

component CandidateCard inherits Surface {
    in property <UiCandidate> candidate;
    callback clicked(int);

    height: 116px;
    background: root.candidate.selected ? #32251f : touch.has-hover ? #2a2522 : #221e1b;
    border-color: root.candidate.selected ? #ff8a65 : #2e2a26;

    touch := TouchArea { clicked => { root.clicked(root.candidate.candidate_id); } }

    Text { x: 16px; y: 14px; width: parent.width - 32px; text: root.candidate.title; color: #ece4dc; font-size: 14px; font-weight: 750; overflow: elide; }
    Text { x: 16px; y: 40px; width: parent.width - 32px; text: root.candidate.subtitle + " · 匹配度 " + root.candidate.score_text; color: #ffc46b; font-size: 12px; overflow: elide; }
    Text { x: 16px; y: 66px; width: parent.width - 32px; height: 34px; text: root.candidate.summary; color: #b6ada4; font-size: 11px; wrap: word-wrap; overflow: elide; }
}

component SettingsTab inherits Rectangle {
    in property <string> title;
    in property <string> desc;
    in property <bool> active;
    callback clicked();

    height: 58px;
    border-radius: 12px;
    background: root.active ? #4a2a1f : touch.has-hover ? #ffffff0d : #00000000;

    touch := TouchArea { clicked => { root.clicked(); } }

    Text { x: 14px; y: 10px; width: parent.width - 42px; text: root.title; color: root.active ? #ff8a65 : #ece4dc; font-size: 14px; font-weight: 700; overflow: elide; }
    Text { x: 14px; y: 32px; width: parent.width - 42px; text: root.desc; color: root.active ? #ffb199 : #847d75; font-size: 11px; overflow: elide; }
    Text { x: parent.width - 24px; y: 20px; text: "›"; color: #847d75; font-size: 16px; }
}

component SettingsRow inherits Rectangle {
    in property <string> title;
    in property <string> desc;
    in property <string> value;
    in property <bool> enabled;
    in property <bool> has_switch;

    height: 76px;
    background: #00000000;

    Text { x: 22px; y: 14px; width: parent.width - 210px; text: root.title; color: #ece4dc; font-size: 14px; font-weight: 650; overflow: elide; }
    Text { x: 22px; y: 39px; width: parent.width - 210px; text: root.desc; color: #847d75; font-size: 12px; overflow: elide; }

    if root.has_switch : Rectangle {
        x: parent.width - 76px;
        y: 24px;
        width: 48px;
        height: 28px;
        border-radius: 14px;
        background: root.enabled ? #ff8a65 : #322c28;
        border-width: 1px;
        border-color: root.enabled ? #ff8a65 : #4a423d;
        Rectangle {
            x: root.enabled ? 23px : 4px;
            y: 4px;
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: #fff7f0;
        }
    }

    if !root.has_switch : Text {
        x: parent.width - 190px;
        y: 27px;
        width: 164px;
        text: root.value;
        color: #b6ada4;
        font-size: 13px;
        horizontal-alignment: right;
        overflow: elide;
    }
}

export component MainWindow inherits Window {
    width: 1360px;
    height: 880px;
    title: "Komorebi";
    background: #14110f;

    in-out property <int> active_page: 0;
    in-out property <bool> detail_open: false;
    in-out property <bool> nav_collapsed: false;
    in-out property <int> settings_section: 0;
    in-out property <string> toast_text;
    in-out property <string> media_path_input;
    in-out property <string> library_search;
    in property <[UiMediaCard]> media_cards;
    in property <[UiMediaRow]> media_rows;
    in property <[UiMediaCard]> recent_cards;
    in property <[UiMediaCard]> match_queue;
    in property <[UiCandidate]> candidates;
    in property <UiSubjectDetail> subject_detail;
    in property <UiCandidate> candidate_preview;
    in property <[string]> detail_files;
    in property <[string]> detail_episodes;
    in property <[UiLogLine]> log_lines;
    in-out property <string> scan_progress;
    in-out property <string> metadata_status;
    in-out property <string> settings_summary;
    in-out property <string> home_summary;
    in-out property <string> library_filter: "all";
    in-out property <string> library_sort: "date";
    in-out property <bool> library_view_grid: true;
    in-out property <bool> bangumi_enabled: true;
    in-out property <bool> bangumi_auto_match: true;
    in-out property <bool> bangumi_cache_images: true;
    in-out property <bool> dandanplay_configured: false;

    callback add_media_path(string);
    callback scan_library();
    callback update_library_search(string);
    callback set_library_filter(string);
    callback set_library_sort(string);
    callback set_library_view_grid(bool);
    callback select_media_id(int);
    callback select_candidate_id(int);
    callback play_selected_media();
    callback save_progress();
    callback clear_progress();
    callback load_danmaku();
    callback match_selected_metadata();
    callback match_all_metadata();
    callback refresh_subject_images();
    callback confirm_selected_candidate();
    callback ignore_selected_metadata();
    callback test_bangumi_connection();

    HorizontalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: root.nav_collapsed ? 72px : 228px;
            background: #1c1916ee;
            border-width: 0px;

            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: #2e2a26;
            }

            Rectangle {
                x: root.nav_collapsed ? 18px : 16px;
                y: 20px;
                width: 36px;
                height: 36px;
                border-radius: 12px;
                background: #ff8a65;
                Text { text: "★"; color: #2a1206; font-size: 20px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
            }

            if !root.nav_collapsed : Text { x: 64px; y: 22px; text: "Komorebi"; color: #ece4dc; font-size: 15px; font-weight: 800; }
            if !root.nav_collapsed : Text { x: 64px; y: 43px; text: "本地番剧库"; color: #847d75; font-size: 11px; }

            VerticalBox {
                x: root.nav_collapsed ? 8px : 12px;
                y: 86px;
                width: root.nav_collapsed ? 56px : parent.width - 24px;
                height: parent.height - 230px;
                spacing: 6px;

                NavItem { label: "Home"; icon: "⌂"; collapsed: root.nav_collapsed; active: root.active_page == 0 && !root.detail_open; clicked => { root.active_page = 0; root.detail_open = false; } }
                NavItem { label: "Library"; icon: "▥"; collapsed: root.nav_collapsed; active: root.active_page == 1 && !root.detail_open; clicked => { root.active_page = 1; root.detail_open = false; } }
                NavItem { label: "Settings"; icon: "⚙"; collapsed: root.nav_collapsed; active: root.active_page == 2 && !root.detail_open; clicked => { root.active_page = 2; root.detail_open = false; } }
            }

            Rectangle {
                x: root.nav_collapsed ? 12px : 12px;
                y: parent.height - 136px;
                width: root.nav_collapsed ? 48px : parent.width - 24px;
                height: root.nav_collapsed ? 48px : 64px;
                border-radius: 14px;
                background: touch.has-hover ? #ffffff0d : #00000000;

                touch := TouchArea {}

                Rectangle { x: root.nav_collapsed ? 10px : 10px; y: root.nav_collapsed ? 10px : 14px; width: 28px; height: 28px; border-radius: 14px; background: #d2c0ff; Text { text: "茉"; color: #251332; font-size: 12px; font-weight: 850; horizontal-alignment: center; vertical-alignment: center; } }
                if !root.nav_collapsed : Text { x: 48px; y: 15px; width: parent.width - 86px; text: "本地用户"; color: #ece4dc; font-size: 12px; overflow: elide; }
                if !root.nav_collapsed : Text { x: 48px; y: 34px; width: parent.width - 86px; text: "3 个媒体库"; color: #847d75; font-size: 10px; overflow: elide; }
                if !root.nav_collapsed : Text { x: parent.width - 30px; y: 22px; text: "●"; color: #b6ada4; font-size: 12px; }
            }

            PrimaryButton {
                x: root.nav_collapsed ? 12px : 18px;
                y: parent.height - 58px;
                width: root.nav_collapsed ? 48px : parent.width - 36px;
                compact: true;
                outlined: true;
                text: root.nav_collapsed ? "›" : "‹ Collapse";
                clicked => { root.nav_collapsed = !root.nav_collapsed; }
            }
        }

        Rectangle {
            background: #14110f;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: #14110f;
                Rectangle { x: 0px; y: 0px; width: parent.width * 0.55; height: parent.height * 0.5; background: #ff8a650a; }
                Rectangle { x: parent.width * 0.45; y: parent.height * 0.45; width: parent.width * 0.55; height: parent.height * 0.55; background: #b18cff08; }
            }

            if root.detail_open : VerticalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 440px;
                    background: root.subject_detail.hero_path == "" ? #2a2522 : #1c1916;
                    clip: true;
                    Image { width: parent.width; height: parent.height; source: root.subject_detail.hero_image; image-fit: cover; }
                    Rectangle { width: parent.width; height: parent.height; background: #14110fcc; }
                    Rectangle { y: parent.height - 150px; width: parent.width; height: 150px; background: #14110f; }

                    PrimaryButton { x: 32px; y: 24px; width: 142px; compact: true; outlined: true; text: "← Back to Library"; clicked => { root.detail_open = false; root.active_page = 1; } }
                    IconButton { x: parent.width - 58px; y: 22px; mark: "⋯"; clicked => { root.toast_text = "更多操作"; } }
                }

                Rectangle {
                    height: parent.height - 440px;
                    background: #00000000;

                    PosterBox {
                        x: 40px;
                        y: -178px;
                        width: 238px;
                        height: 356px;
                        card: {
                            media_id: root.subject_detail.media_id,
                            subject_id: root.subject_detail.subject_id,
                            title: root.subject_detail.title,
                            subtitle: root.subject_detail.title_cn,
                            status_text: root.subject_detail.match_status,
                            match_status: root.subject_detail.subject_id > 0 ? "matched" : "unmatched",
                            progress_percent: 0,
                            episode_text: "",
                            poster_path: root.subject_detail.poster_path,
                            poster_image: root.subject_detail.poster_image,
                            has_cached_poster: root.subject_detail.poster_path != "",
                        };
                    }

                    if root.subject_detail.rating_text != "-" : Surface {
                        x: 40px;
                        y: 194px;
                        width: 238px;
                        height: 86px;
                        Text { x: 18px; y: 14px; text: "★"; color: #ffc46b; font-size: 18px; font-weight: 900; }
                        Text { x: 44px; y: 11px; text: root.subject_detail.rating_text; color: #ece4dc; font-size: 24px; font-weight: 850; }
                        Text { x: parent.width - 72px; y: 20px; text: "#" + root.subject_detail.rank_text; color: #847d75; font-size: 12px; }
                        Text { x: 18px; y: 54px; text: "Bangumi 评分"; color: #847d75; font-size: 11px; }
                    }

                    Rectangle {
                        x: 318px;
                        y: -250px;
                        width: parent.width - 358px;
                        height: parent.height + 220px;
                        background: #00000000;

                        HorizontalBox {
                            x: 0px;
                            y: 0px;
                            spacing: 8px;
                            Badge { text: root.subject_detail.match_status; tone: root.subject_detail.subject_id > 0 ? "success" : "accent"; }
                            Badge { text: root.subject_detail.cache_status == "" ? "METADATA" : root.subject_detail.cache_status; tone: "success"; }
                        }

                        Text {
                            x: 0px;
                            y: 42px;
                            width: parent.width - 40px;
                            height: 54px;
                            text: root.subject_detail.title;
                            color: #ece4dc;
                            font-size: 44px;
                            font-weight: 850;
                            overflow: elide;
                        }

                        Text {
                            x: 2px;
                            y: 102px;
                            width: parent.width - 44px;
                            height: 26px;
                            text: root.subject_detail.title_cn + " · " + root.subject_detail.air_date;
                            color: #b6ada4;
                            font-size: 18px;
                            overflow: elide;
                        }

                        Text {
                            x: 0px;
                            y: 150px;
                            width: parent.width - 80px;
                            height: 82px;
                            text: root.subject_detail.summary;
                            color: #b6ada4;
                            font-size: 15px;
                            wrap: word-wrap;
                            overflow: elide;
                        }

                        HorizontalBox {
                            x: 0px;
                            y: 252px;
                            spacing: 10px;
                            PrimaryButton { text: "▶ Play"; clicked => { root.play_selected_media(); root.toast_text = "正在打开播放器"; } }
                            PrimaryButton { tonal: true; text: "弹幕"; clicked => { root.load_danmaku(); root.toast_text = "正在加载弹幕"; } }
                            PrimaryButton { outlined: true; text: "Rematch"; clicked => { root.match_selected_metadata(); root.toast_text = "正在重新匹配"; } }
                            if root.subject_detail.subject_id == 0 : PrimaryButton { outlined: true; text: "Confirm"; clicked => { root.confirm_selected_candidate(); root.toast_text = "匹配已确认"; } }
                            PrimaryButton { outlined: true; text: "Cache Images"; clicked => { root.refresh_subject_images(); root.toast_text = "正在缓存图片"; } }
                        }

                        if root.subject_detail.subject_id == 0 : Rectangle {
                            x: 0px;
                            y: 322px;
                            width: parent.width - 40px;
                            height: 184px;
                            Text { text: "未匹配 · 搜索 Bangumi"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                            LineEdit { x: 0px; y: 42px; width: 420px; height: 40px; text: root.subject_detail.title; placeholder-text: "搜索 Bangumi…"; }
                            HorizontalBox {
                                y: 100px;
                                spacing: 12px;
                                for candidate in root.candidates : CandidateCard {
                                    width: 280px;
                                    candidate: candidate;
                                    clicked(id) => { root.select_candidate_id(id); root.toast_text = "已选择候选条目"; }
                                }
                            }
                        }

                        HorizontalBox {
                            x: 0px;
                            y: root.subject_detail.subject_id == 0 ? 540px : 336px;
                            width: parent.width - 40px;
                            spacing: 22px;

                            VerticalBox {
                                spacing: 10px;
                                Text { text: "本地文件"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                                Surface {
                                    height: 238px;
                                    ListView {
                                        x: 10px;
                                        y: 8px;
                                        width: parent.width - 20px;
                                        height: parent.height - 16px;
                                        for file in root.detail_files : Rectangle {
                                            height: 42px;
                                            Text { x: 8px; width: parent.width - 86px; text: file; color: #b6ada4; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                            PrimaryButton { x: parent.width - 70px; y: 6px; width: 62px; compact: true; tonal: true; text: "Play"; clicked => { root.play_selected_media(); } }
                                        }
                                    }
                                }
                            }

                            VerticalBox {
                                spacing: 10px;
                                Text { text: "分集"; color: #ece4dc; font-size: 20px; font-weight: 800; }
                                Surface {
                                    height: 238px;
                                    ListView {
                                        x: 10px;
                                        y: 8px;
                                        width: parent.width - 20px;
                                        height: parent.height - 16px;
                                        for episode in root.detail_episodes : Rectangle {
                                            height: 38px;
                                            Text { x: 8px; width: parent.width - 16px; text: episode; color: #b6ada4; font-size: 12px; vertical-alignment: center; overflow: elide; }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !root.detail_open && root.active_page == 0 : ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: parent.width;
                viewport-height: 1704px;

                VerticalBox {
                    width: parent.width;
                    height: 1704px;
                    padding: 0px;
                    spacing: 0px;

                Rectangle {
                    height: 560px;
                    background: #1c1916;
                    clip: true;
                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.recent_cards.length > 0 ? root.recent_cards[0].poster_image : @image-url("");
                        image-fit: cover;
                    }
                    Rectangle { width: parent.width; height: parent.height; background: #14110fd8; }
                    Rectangle { width: parent.width * 0.55; height: parent.height; background: #14110f88; }
                    Rectangle { y: parent.height - 116px; width: parent.width; height: 116px; background: #14110f; }

                    HorizontalBox {
                        x: 40px;
                        y: 292px;
                        spacing: 8px;
                        Badge { text: "NEW EPISODE"; tone: "primary"; }
                        Badge { text: "CONTINUE"; tone: "accent"; }
                        Badge { text: "METADATA READY"; tone: "success"; }
                    }
                    Text { x: 42px; y: 334px; text: "Featured · 2026"; color: #847d75; font-size: 12px; font-weight: 800; }
                    Text { x: 40px; y: 358px; width: parent.width - 420px; height: 64px; text: root.recent_cards.length > 0 ? root.recent_cards[0].title : "Komorebi"; color: #ece4dc; font-size: 56px; font-weight: 850; overflow: elide; }
                    Text { x: 42px; y: 426px; width: parent.width - 480px; height: 48px; text: root.recent_cards.length > 0 ? root.recent_cards[0].subtitle : "本地番剧库"; color: #b6ada4; font-size: 18px; overflow: elide; }
                    Text { x: 42px; y: 472px; width: 620px; height: 46px; text: "本地扫描、Bangumi 元数据、弹幕匹配、播放进度与缓存图片聚合在一个桌面应用里。"; color: #b6ada4; font-size: 15px; wrap: word-wrap; overflow: elide; }

                    HorizontalBox {
                        x: 42px;
                        y: 522px;
                        spacing: 12px;
                        PrimaryButton { width: 170px; text: "继续观看"; clicked => { if root.recent_cards.length > 0 { root.select_media_id(root.recent_cards[0].media_id); root.detail_open = true; } } }
                        PrimaryButton { width: 150px; tonal: true; text: "Add to Queue"; clicked => { root.toast_text = "已加入队列"; } }
                        PrimaryButton { width: 104px; outlined: true; text: "More"; clicked => { root.active_page = 1; } }
                    }
                }

                Rectangle {
                    height: 314px;
                    background: #00000000;
                    SectionTitle { x: 40px; y: 24px; width: parent.width - 80px; title: "继续观看"; subtitle: "Continue Watching"; view_all: true; view_all_clicked => { root.active_page = 1; } }
                    HorizontalBox {
                        x: 40px;
                        y: 90px;
                        width: parent.width - 80px;
                        spacing: 18px;
                        for card in root.recent_cards : ContinueCard {
                            width: (parent.width - 18px) / 2;
                            card: card;
                            clicked(id) => { root.select_media_id(id); root.detail_open = true; }
                        }
                    }
                }

                Rectangle {
                    height: 400px;
                    background: #00000000;
                    SectionTitle { x: 40px; y: 8px; width: parent.width - 80px; title: "最近添加"; subtitle: "Recently Added"; view_all: true; view_all_clicked => { root.active_page = 1; } }
                    HorizontalBox {
                        x: 40px;
                        y: 74px;
                        spacing: 18px;
                        for card in root.recent_cards : MediaCard {
                            card: card;
                            clicked(id) => { root.select_media_id(id); root.detail_open = true; }
                        }
                    }
                }

                Rectangle {
                    height: 180px;
                    background: #00000000;
                    SectionTitle { x: 40px; y: 0px; width: parent.width - 80px; title: "媒体库概览"; subtitle: "Library Overview"; }
                    HorizontalBox {
                        x: 40px;
                        y: 64px;
                        width: parent.width - 80px;
                        spacing: 12px;
                        StatCard { width: (parent.width - 48px) / 5; label: "Indexed Media"; value: root.home_summary; hint: "local SQLite"; }
                        StatCard { width: (parent.width - 48px) / 5; label: "Scan"; value: root.scan_progress; hint: "background task"; }
                        StatCard { width: (parent.width - 48px) / 5; label: "Metadata"; value: root.metadata_status; hint: "Bangumi"; }
                        StatCard { width: (parent.width - 48px) / 5; label: "Cache Size"; value: "local"; hint: "poster + metadata"; }
                        StatCard { width: (parent.width - 48px) / 5; label: "Last Scan"; value: "manual"; hint: "Scan Now"; }
                    }
                }

                Rectangle {
                    height: 250px;
                    background: #00000000;
                    SectionTitle { x: 40px; y: 0px; width: parent.width - 80px; title: "主题预览"; subtitle: "Light · Dim · Dark"; }
                    HorizontalBox {
                        x: 40px;
                        y: 64px;
                        width: parent.width - 80px;
                        spacing: 16px;
                        Surface { width: (parent.width - 32px) / 3; height: 126px; Text { x: 18px; y: 16px; text: "Light"; color: #ece4dc; font-size: 14px; font-weight: 700; } Badge { x: parent.width - 94px; y: 14px; text: "Available"; tone: "accent"; } Rectangle { x: 18px; y: 60px; width: parent.width - 36px; height: 42px; border-radius: 9px; background: #fdf8f3; } }
                        Surface { width: (parent.width - 32px) / 3; height: 126px; Text { x: 18px; y: 16px; text: "Dim (current)"; color: #ece4dc; font-size: 14px; font-weight: 700; } Badge { x: parent.width - 76px; y: 14px; text: "Active"; tone: "primary"; } Rectangle { x: 18px; y: 60px; width: parent.width - 36px; height: 42px; border-radius: 9px; background: #2a2522; } }
                        Surface { width: (parent.width - 32px) / 3; height: 126px; Text { x: 18px; y: 16px; text: "Dark"; color: #ece4dc; font-size: 14px; font-weight: 700; } Badge { x: parent.width - 94px; y: 14px; text: "Available"; tone: "accent"; } Rectangle { x: 18px; y: 60px; width: parent.width - 36px; height: 42px; border-radius: 9px; background: #0a0908; } }
                    }
                }
                }
            }

            if !root.detail_open && root.active_page == 1 : Rectangle {
                width: parent.width;
                height: parent.height;

                Text { x: 40px; y: 38px; text: "媒体库"; color: #ece4dc; font-size: 36px; font-weight: 850; }
                Text { x: 42px; y: 88px; text: root.home_summary; color: #b6ada4; font-size: 14px; }
                PrimaryButton { x: parent.width - 286px; y: 42px; width: 126px; outlined: true; text: "Add Folder"; clicked => { root.active_page = 2; root.settings_section = 0; } }
                PrimaryButton { x: parent.width - 148px; y: 42px; width: 108px; text: "Scan Now"; clicked => { root.scan_library(); root.toast_text = "已开始扫描媒体目录"; } }

                Surface {
                    x: 40px;
                    y: 128px;
                    width: parent.width - 80px;
                    height: 64px;
                    background: #1c1916cc;
                    LineEdit {
                        x: 14px;
                        y: 12px;
                        width: 300px;
                        height: 40px;
                        text <=> root.library_search;
                        placeholder-text: "搜索标题、文件名、标签…";
                        edited(text) => { root.update_library_search(text); }
                    }
                    Chip { x: 334px; y: 16px; text: "All"; selected: root.library_filter == "all"; clicked => { root.set_library_filter("all"); } }
                    Chip { x: 422px; y: 16px; text: "Watching"; selected: root.library_filter == "watching"; clicked => { root.set_library_filter("watching"); } }
                    Chip { x: 540px; y: 16px; text: "Completed"; selected: root.library_filter == "completed"; clicked => { root.set_library_filter("completed"); } }
                    Chip { x: 666px; y: 16px; text: "Unmatched"; selected: root.library_filter == "unmatched"; clicked => { root.set_library_filter("unmatched"); } }
                    Chip { x: 792px; y: 16px; text: "Tentative"; selected: root.library_filter == "tentative"; clicked => { root.set_library_filter("tentative"); } }

                    PrimaryButton { x: parent.width - 368px; y: 15px; width: 118px; compact: true; tonal: root.library_sort == "date"; outlined: root.library_sort != "date"; text: "Date Added"; clicked => { root.set_library_sort("date"); } }
                    PrimaryButton { x: parent.width - 240px; y: 15px; width: 92px; compact: true; tonal: root.library_sort == "title"; outlined: root.library_sort != "title"; text: "Title"; clicked => { root.set_library_sort("title"); } }
                    IconButton { x: parent.width - 136px; y: 13px; mark: "▦"; active: root.library_view_grid; clicked => { root.set_library_view_grid(true); } }
                    IconButton { x: parent.width - 88px; y: 13px; mark: "☰"; active: !root.library_view_grid; clicked => { root.set_library_view_grid(false); } }
                }

                if root.media_rows.length == 0 : Surface {
                    x: 40px;
                    y: 220px;
                    width: parent.width - 80px;
                    height: 500px;
                    Text { y: 182px; width: parent.width; text: root.library_search == "" && root.library_filter == "all" ? "媒体库为空" : "没有找到匹配项目"; color: #ece4dc; font-size: 26px; font-weight: 850; horizontal-alignment: center; }
                    Text { y: 226px; width: parent.width; text: root.library_search == "" && root.library_filter == "all" ? "添加目录并扫描后会显示番剧条目。" : "调整搜索、筛选或排序后重试。"; color: #847d75; font-size: 14px; horizontal-alignment: center; }
                    PrimaryButton { x: parent.width / 2 - 70px; y: 276px; width: 140px; text: "Add Folder"; clicked => { root.active_page = 2; root.settings_section = 0; } }
                }

                if root.media_rows.length > 0 && root.library_view_grid : HorizontalBox {
                    x: 40px;
                    y: 220px;
                    width: parent.width - 80px;
                    height: parent.height - 246px;
                    spacing: 26px;

                    ListView {
                        width: root.subject_detail.media_id > 0 ? parent.width - 348px : parent.width;
                        height: parent.height;
                        for row in root.media_rows : HorizontalBox {
                            height: 342px;
                            spacing: 18px;
                            if row.show0 : MediaCard { card: row.card0; selected: row.card0.media_id == root.subject_detail.media_id; clicked(id) => { root.select_media_id(id); } }
                            if row.show1 : MediaCard { card: row.card1; selected: row.card1.media_id == root.subject_detail.media_id; clicked(id) => { root.select_media_id(id); } }
                            if row.show2 : MediaCard { card: row.card2; selected: row.card2.media_id == root.subject_detail.media_id; clicked(id) => { root.select_media_id(id); } }
                            if row.show3 : MediaCard { card: row.card3; selected: row.card3.media_id == root.subject_detail.media_id; clicked(id) => { root.select_media_id(id); } }
                            if row.show4 : MediaCard { card: row.card4; selected: row.card4.media_id == root.subject_detail.media_id; clicked(id) => { root.select_media_id(id); } }
                        }
                    }

                    if root.subject_detail.media_id > 0 : Surface {
                        width: 320px;
                        height: 508px;
                        PosterBox { x: 18px; y: 18px; width: 88px; height: 132px; small: true; card: { media_id: root.subject_detail.media_id, subject_id: root.subject_detail.subject_id, title: root.subject_detail.title, subtitle: root.subject_detail.title_cn, status_text: root.subject_detail.match_status, match_status: root.subject_detail.subject_id > 0 ? "matched" : "unmatched", progress_percent: 0, episode_text: "", poster_path: root.subject_detail.poster_path, poster_image: root.subject_detail.poster_image, has_cached_poster: root.subject_detail.poster_path != "" }; }
                        Text { x: 124px; y: 24px; width: 170px; text: root.subject_detail.title; color: #ece4dc; font-size: 15px; font-weight: 750; overflow: elide; }
                        Text { x: 124px; y: 50px; width: 170px; text: root.subject_detail.title_cn; color: #847d75; font-size: 12px; overflow: elide; }
                        Badge { x: 124px; y: 84px; width: 92px; text: root.subject_detail.match_status; tone: root.subject_detail.subject_id > 0 ? "success" : "accent"; }
                        Text { x: 18px; y: 172px; width: parent.width - 36px; height: 98px; text: root.subject_detail.summary; color: #b6ada4; font-size: 13px; wrap: word-wrap; overflow: elide; }
                        SettingsRow { x: 0px; y: 286px; width: parent.width; title: "文件"; desc: "本地文件数量"; value: root.detail_files.length + ""; has_switch: false; }
                        SettingsRow { x: 0px; y: 356px; width: parent.width; title: "评分"; desc: "Bangumi"; value: root.subject_detail.rating_text; has_switch: false; }
                        PrimaryButton { x: 18px; y: 438px; width: parent.width - 36px; text: "打开详情"; clicked => { root.detail_open = true; } }
                    }
                }

                if root.media_cards.length > 0 && !root.library_view_grid : Surface {
                    x: 40px;
                    y: 220px;
                    width: parent.width - 80px;
                    height: parent.height - 246px;
                    clip: true;
                    Rectangle { height: 42px; background: #1c1916; Text { x: 72px; text: "Title"; color: #847d75; font-size: 11px; font-weight: 800; vertical-alignment: center; } Text { x: parent.width - 418px; text: "Status"; color: #847d75; font-size: 11px; font-weight: 800; vertical-alignment: center; } Text { x: parent.width - 300px; text: "Progress"; color: #847d75; font-size: 11px; font-weight: 800; vertical-alignment: center; } }
                    ListView {
                        y: 42px;
                        width: parent.width;
                        height: parent.height - 42px;
                        for card in root.media_cards : ListRow {
                            card: card;
                            clicked(id) => { root.select_media_id(id); root.detail_open = true; }
                        }
                    }
                }
            }

            if !root.detail_open && root.active_page == 2 : Rectangle {
                width: parent.width;
                height: parent.height;


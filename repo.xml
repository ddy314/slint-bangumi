<file path="frontend/src/index.css">
@import "tailwindcss";

@theme {
  --font-sans: "Inter", "Segoe UI Variable", "Segoe UI", "PingFang SC",
    "Microsoft YaHei", system-ui, sans-serif;

  /* M3 / Fluent inspired tokens — warm dim tonal */
  --color-bg: #14110f;
  --color-surface: #1c1916;
  --color-surface-1: #221e1b;
  --color-surface-2: #2a2522;
  --color-surface-3: #322c28;
  --color-surface-4: #3b3531;
  --color-outline: #4a423d;
  --color-outline-soft: #2e2a26;

  --color-on-surface: #ece4dc;
  --color-on-surface-muted: #b6ada4;
  --color-on-surface-faint: #847d75;

  --color-primary: #ff8a65;
  --color-primary-soft: #4a2a1f;
  --color-on-primary: #2a1206;

  --color-accent: #b18cff;
  --color-success: #6dd58c;
  --color-warning: #ffc46b;
  --color-danger: #ff6b6b;
}

html,
body,
#root {
  height: 100%;
  background: var(--color-bg);
  color: var(--color-on-surface);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

/* Scrollbar — subtle, fluent-ish */
*::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}
*::-webkit-scrollbar-track {
  background: transparent;
}
*::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 999px;
  border: 2px solid transparent;
  background-clip: padding-box;
}
*::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.16);
  background-clip: padding-box;
  border: 2px solid transparent;
}

/* Mica-like noise */
.mica {
  background-image:
    radial-gradient(120% 80% at 0% 0%, rgba(255, 138, 101, 0.08), transparent 60%),
    radial-gradient(120% 80% at 100% 100%, rgba(177, 140, 255, 0.06), transparent 60%),
    linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
}

.acrylic {
  background: rgba(28, 25, 22, 0.72);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
}

.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { scrollbar-width: none; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.anim-fade-up { animation: fadeUp .35s ease-out both; }

@keyframes shimmer {
  0% { background-position: -400px 0; }
  100% { background-position: 400px 0; }
}
.skeleton {
  background: linear-gradient(90deg, var(--color-surface-2) 0%, var(--color-surface-3) 50%, var(--color-surface-2) 100%);
  background-size: 800px 100%;
  animation: shimmer 1.4s linear infinite;
}

@keyframes snackbarIn {
  from { opacity: 0; transform: translate(-50%, 20px); }
  to { opacity: 1; transform: translate(-50%, 0); }
}
.anim-snackbar { animation: snackbarIn .3s cubic-bezier(.2,.8,.2,1) both; }
</file>

